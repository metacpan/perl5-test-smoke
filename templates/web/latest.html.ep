% my @hero_stats = (
%   { label => 'Hosts',        value => commify($report_count) },
%   { label => 'Latest plevel', value => qq(<span class="code-inline">$latest_plevel</span>) },
%   { label => 'PASS (24h)',   value => commify($stats->{pass_24h}  // 0), variant => 'success' },
