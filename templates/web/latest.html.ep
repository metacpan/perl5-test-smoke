% );
%= include 'components/hero', eyebrow => 'Live smoke ingest', title => 'Latest <em>smoke</em> results.', lede => 'The most recent run from each host, freshest plevel first. Click a row to open the full report.', stats => \@hero_stats

%= include 'web/_latest_region', path => $path, reports => $reports, report_count => $report_count, page => $page, reports_per_page => $reports_per_page, latest_plevel => $latest_plevel, filter => $filter
