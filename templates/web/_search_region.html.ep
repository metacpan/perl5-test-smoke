% # `available` is computed against the OTHER active filters, so picking
% # arch=aarch64 narrows perl_version, branch, etc. to only what exists in
% # the matching reports. We render the available values as <option>s, and
% # if the user's current selection isn't in the available list (zero
% # matches for that combination), we pin it as an extra <option> so the
% # active filter stays visible and can be cleared.
% my $arch_opts    = $available->{architectures}     // [];
% my $osnm_opts    = $available->{osnames}           // [];
% my $osvs_opts    = $available->{osversions}        // [];
% my $perl_opts    = $available->{perl_versions}     // [];
% my $branch_opts  = $available->{branches}          // [];
% my $host_opts    = $available->{hostnames}         // [];
% my $comp_opts    = $available->{compilers}         // [];
% my $cver_opts    = $available->{compiler_versions} // [];
% my $smkv_opts    = $available->{smoker_versions}   // [];
% my $summary_opts = $available->{summaries}         // [];
% my $sel_arch     = $filter->{selected_arch}    // '';
% my $sel_osnm     = $filter->{selected_osnm}    // '';
% my $sel_osvs     = $filter->{selected_osvs}    // '';
% my $sel_perl     = $filter->{selected_perl}    // '';
% my $sel_branch   = $filter->{selected_branch}  // '';
% my $sel_host     = $filter->{selected_host}    // '';
% my $sel_comp     = $filter->{selected_comp}    // '';
% my $sel_cver     = $filter->{selected_cver}    // '';
% my $sel_smkv     = $filter->{selected_smkv}    // '';
% my $sel_summary  = $filter->{selected_summary} // '';
% my $date_from    = $filter->{date_from}        // '';
% my $date_to      = $filter->{date_to}          // '';
% my %arch_have    = map { $_ => 1 } @$arch_opts;
% my %osnm_have    = map { $_ => 1 } @$osnm_opts;
% my %osvs_have    = map { $_ => 1 } @$osvs_opts;
% my %perl_have    = map { $_ => 1 } @$perl_opts;
% my %branch_have  = map { $_ => 1 } @$branch_opts;
% my %host_have    = map { $_ => 1 } @$host_opts;
% my %comp_have    = map { $_ => 1 } @$comp_opts;
% my %cver_have    = map { $_ => 1 } @$cver_opts;
% my %smkv_have    = map { $_ => 1 } @$smkv_opts;
% my %summary_have = map { $_ => 1 } @$summary_opts;
%
% my $mk_options = sub {
%   my ($values, $sel, $extras) = @_;
%   $extras //= [];
%   my @opts = ({ value => 'all', label => 'all', selected => ($sel eq '' || $sel eq 'all') });
%   push @opts, @$extras;
%   for my $v (@$values) {
%     push @opts, { value => $v, label => $v, selected => ($sel eq $v) };
%   }
%   return \@opts;
% };
% my $perl_extras   = [{ value => 'latest', label => 'latest', selected => ($sel_perl eq 'latest') }];
% my $arch_options    = $mk_options->($arch_opts,    $sel_arch);
% my $osnm_options    = $mk_options->($osnm_opts,    $sel_osnm);
% my $osvs_options    = $mk_options->($osvs_opts,    $sel_osvs);
% my $perl_options    = $mk_options->($perl_opts,    $sel_perl,   $perl_extras);
% my $branch_options  = $mk_options->($branch_opts,  $sel_branch);
% my $host_options    = $mk_options->($host_opts,    $sel_host);
% my $comp_options    = $mk_options->($comp_opts,    $sel_comp);
% my $cver_options    = $mk_options->($cver_opts,    $sel_cver);
% my $smkv_options    = $mk_options->($smkv_opts,    $sel_smkv);
% my $summary_options = $mk_options->($summary_opts, $sel_summary);
%
% my $pinned = sub {
%   my ($sel, $have) = @_;
%   ($sel ne '' && $sel ne 'all' && !$have->{$sel})
%     ? [{ value => $sel, label => $sel, selected => 1 }] : [];
% };

<div id="search-region">
  <form id="search-form"
        class="search-form"
        hx-get="/search"
        hx-trigger="change delay:200ms from:select, change delay:200ms from:input[type=checkbox], change delay:200ms from:input[type=date]"
        hx-target="#search-region"
        hx-swap="outerHTML"
        hx-include="closest form"
        hx-push-url="true">
    <div class="filter-grid">
      %= include 'components/form_field', label => 'Architecture',     name => 'selected_arch',    type => 'select', options => $arch_options,    extra => $pinned->($sel_arch,    \%arch_have)
      %= include 'components/form_field', label => 'OS name',          name => 'selected_osnm',    type => 'select', options => $osnm_options,    extra => $pinned->($sel_osnm,    \%osnm_have)
      %= include 'components/form_field', label => 'OS version',       name => 'selected_osvs',    type => 'select', options => $osvs_options,    extra => $pinned->($sel_osvs,    \%osvs_have)
      %= include 'components/form_field', label => 'Perl version',     name => 'selected_perl',    type => 'select', options => $perl_options,    extra => $pinned->($sel_perl,    \%perl_have)
      %= include 'components/form_field', label => 'Branch',           name => 'selected_branch',  type => 'select', options => $branch_options,  extra => $pinned->($sel_branch,  \%branch_have)
      %= include 'components/form_field', label => 'Hostname',         name => 'selected_host',    type => 'select', options => $host_options,    extra => $pinned->($sel_host,    \%host_have)
      %= include 'components/form_field', label => 'Compiler',         name => 'selected_comp',    type => 'select', options => $comp_options,    extra => $pinned->($sel_comp,    \%comp_have)
      %= include 'components/form_field', label => 'Compiler version', name => 'selected_cver',    type => 'select', options => $cver_options,    extra => $pinned->($sel_cver,    \%cver_have)
      %= include 'components/form_field', label => 'Smoker',           name => 'selected_smkv',    type => 'select', options => $smkv_options,    extra => $pinned->($sel_smkv,    \%smkv_have)
      %= include 'components/form_field', label => 'Status',           name => 'selected_summary', type => 'select', options => $summary_options, extra => $pinned->($sel_summary, \%summary_have)
      %= include 'components/form_field', label => 'From date',        name => 'date_from',        type => 'date',   value => $date_from
      %= include 'components/form_field', label => 'To date',          name => 'date_to',          type => 'date',   value => $date_to
    </div>
% my $active_count = grep { $_ ne '' && $_ ne 'all' } $sel_arch, $sel_osnm, $sel_osvs, $sel_perl, $sel_branch, $sel_host, $sel_comp, $sel_cver, $sel_smkv, $sel_summary, $date_from, $date_to;
% if ($active_count) {
    <div class="filter-actions">
      <span class="filter-count"><%= $active_count %> active <%= $active_count == 1 ? 'filter' : 'filters' %></span>
      <button type="button" class="btn btn-ghost btn-sm"
              hx-get="/search"
              hx-target="#search-region"
              hx-swap="outerHTML"
              hx-push-url="/search">Clear all</button>
    </div>
% }
  </form>

  %= include 'components/pagination_summary', shown => scalar @{ $results->{reports} }, total => $results->{report_count}, noun => 'reports'

% if (!@{ $results->{reports} }) {
  %= include 'components/empty_state', title => 'No reports match your filters', desc => 'Try clearing one or more filters above, or reset everything to start over.', icon => '&empty;', actions => begin
    %= btn_link 'Reset filters', '/search', 'primary', 'sm'
  % end
% } else {
%   my @headers = (
%     { label => 'Host',         sort => 'host' },
%     { label => 'Architecture', sort => 'arch' },
%     { label => 'OS',           sort => 'os' },
%     { label => 'Perl',         sort => 'perl' },
%     { label => 'Status',       sort => 'status' },
%     { label => 'Smoker',       sort => 'smoker' },
%     { label => 'Smoke date',   sort => 'date' },
%   );
  %= include 'components/data_table', headers => \@headers, tbody_id => 'report-rows', body => begin
    %= include 'web/_reports_rows', path => '/search', reports => $results->{reports}, report_count => $results->{report_count}, page => $page, reports_per_page => $reports_per_page, filter => $filter
  % end
% }
</div>
