% layout 'default';
% use Mojo::Util 'xml_escape';
% title "Failures for " . ($test // 'unknown');
% my @crumbs = (
%   { label => 'Home',   href => '/' },
%   { label => 'Matrix', href => '/matrix' },
% );
% if (defined $test && length $test) {
%   push @crumbs, { label => $test };
% } else {
%   push @crumbs, { label => 'Submatrix' };
% }
% my $safe_test = xml_escape($test // '');
% my $safe_pver = xml_escape($pversion // '');
% stash page_header => {
%   crumbs => \@crumbs,
%   title  => $test
%     ? ($pversion ? qq(Failures for <code class="code-inline">$safe_test</code> on perl <code class="code-inline">$safe_pver</code>)
%                  : qq(Failures for <code class="code-inline">$safe_test</code>))
%     : 'Submatrix',
% };

% if (!defined $test || !length $test) {
  %= include 'components/empty_state', title => 'Missing test parameter', desc => 'The /submatrix endpoint needs a `test=...` query parameter. Try clicking a cell from the matrix.', icon => '?', actions => begin
    %= btn_link 'Back to matrix', '/matrix', 'primary', 'sm'
  % end
% } elsif (!@$reports) {
  %= include 'components/empty_state', title => 'No matching reports', desc => 'No smoke reports record a failure of this test for this Perl version.', icon => '&empty;', actions => begin
    %= btn_link 'Back to matrix', '/matrix', 'secondary', 'sm'
  % end
% } else {
  %= include 'components/data_table', headers => ['Perl', 'git_describe', 'Host', 'OS'], body => begin
% for my $r (@$reports) {
    <tr>
      <td><a href="/report/<%= $r->{id} %>"><code class="code-inline"><%= $r->{perl_id} %></code></a></td>
      <td><code class="code-inline"><%= $r->{git_describe} %></code></td>
      <td><%= $r->{hostname} %></td>
      <td><%= $r->{osname} %> <%= $r->{osversion} %></td>
    </tr>
% }
  % end
% }
